{
  "name": "farmwallet-rice-shops",
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "description": "FarmWallet Rice Shops - USSD platform for shops to sell rice",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "create-admin": "node scripts/create-admin.js",
    "register-exhibitor": "node scripts/register-exhibitor.js",
    "verify-inventory": "node scripts/verify-existing-inventory.js",
    "seed-products": "node scripts/seed-products.js",
    "add-bag-size": "node scripts/add-bag-size-columns.js",
    "add-mechanization": "node scripts/add-mechanization-tables.js",
    "add-mechanization-transactions": "node scripts/add-mechanization-transactions-table.js",
    "add-provider-name-to-transactions": "node scripts/add-provider-name-to-transactions.js",
    "seed-mechanization": "node scripts/seed-mechanization.js",
    "add-tractor-registration": "node scripts/add-tractor-registration-column.js",
    "require-tractor-registration": "node scripts/require-tractor-registration.js",
    "add-provider-pin-hash": "node scripts/add-provider-pin-hash.js",
    "add-provider-code": "node scripts/add-provider-code.js",
    "require-provider-code": "node scripts/require-provider-code.js",
    "add-mech-service-verification": "node scripts/add-mech-service-verification.js",
    "add-purification-service": "node scripts/add-purification-service.js",
    "add-ussd-sessions": "node scripts/add-ussd-sessions.js",
    "add-vsla-group-code": "node scripts/add-vsla-group-code.js",
    "add-ussd-extensions": "node scripts/add-ussd-extensions.js",
    "add-data-submissions": "node scripts/add-data-submissions.js",
    "register-provider": "node scripts/register-provider.js",
    "docker:build": "docker build -t farmwallet-rice .",
    "docker:buildx": "docker buildx build --platform linux/amd64,linux/arm64 -t hideen124/farmwallet-rice:latest --push .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "keywords": [
    "ussd",
    "ghana",
    "rice",
    "farmwallet",
    "shops",
    "exhibition"
  ],
  "author": "FarmWallet",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
