# Database (required)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=farmwallet_ghana_rice
DB_USER=farmwallet
DB_PASSWORD=your_password

# Paystack (for real payments - omit for mock)
PAYSTACK_SECRET_KEY=sk_test_xxxx

# VSL/VSLA external database (optional - for VSLA menu & API)
# VSL_DB_HOST=
# VSL_DB_PORT=3306
# VSL_DB_NAME=
# VSL_DB_USER=
# VSL_DB_PASSWORD=
# VSL_DB_DIALECT=mysql

# Optional
FARMWALLET_COMMISSION_PERCENT=2
ADMIN_API_KEY=your_admin_api_key
PUBLIC_BASE_URL=https://ussdapi.farmwallet.org
PAYSTACK_CALLBACK_URL=https://ussdapi.farmwallet.org

# Strong SSL/TLS (place certs in ssl/ or set paths)
# SSL_CERT_PATH=ssl/server.crt
# SSL_KEY_PATH=ssl/server.key
# SSL_CA_PATH=ssl/server.ca-bundle
# HTTPS_PORT=3443
# TLS_MIN_VERSION=TLSv1.2
# VSLA_API_KEY=optional_separate_key  # Falls back to ADMIN_API_KEY
ARKESEL_API_KEY=your_arkesel_key
JWT_SECRET=your-jwt-secret-min-32-chars
